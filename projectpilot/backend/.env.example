# ProjectPilot Backend — Environment Variables
# Copy this file to .env and fill in your values

NODE_ENV=development
PORT=5000

# PostgreSQL Database
DATABASE_URL=postgresql://username:password@localhost:5432/projectpilot

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:5173,https://your-frontend.onrender.com

# Render PostgreSQL (auto-set by Render)
# DATABASE_URL is automatically injected by Render when you add a PostgreSQL service
